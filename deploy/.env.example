# Longmen deployment configuration — copy to .env and edit.
#   cp .env.example .env
#
# These values override the image-baked TOML defaults. Anything not set here
# falls back to a safe baked/default value. Secrets do NOT go here — use docker
# secrets (files under ./secrets/); see ./secrets/README.md.

# ── Images ────────────────────────────────────────────────────────────────────
# For a pull-based deploy, set these to your Docker Hub namespace + tag, e.g.
#   GATEWAY_IMAGE=docker.io/<namespace>/longmen-gateway:1.0.0
GATEWAY_IMAGE=longmen-gateway:latest
RAG_IMAGE=longmen-rag:latest

# ── Host mount paths ──────────────────────────────────────────────────────────
# MODELS_DIR holds your tokenizer.json and embedding model (mounted read-only at
# /models in both containers). WORKSPACE is your code (gateway). DOCS is the
# documents RAG indexes (read-only).
MODELS_DIR=./models
WORKSPACE=./workspace
DOCS=./docs

# ── Gateway — required ────────────────────────────────────────────────────────
GATEWAY__MODEL__MODEL_NAME=qwen3-32b
GATEWAY__MODEL__TOKENIZER_PATH=/models/tokenizer.json
# Your vLLM endpoint. Keep http://vllm:8000 if you enable the bundled vllm
# service; otherwise point at your external server.
GATEWAY__MODEL__VLLM_BASE_URL=http://vllm:8000

# ── Gateway — optional ────────────────────────────────────────────────────────
#GATEWAY__MODEL__CONTEXT_LIMIT=120000
#GATEWAY__MODEL__MAX_TOKENS=32000
#GATEWAY__RAG__ENABLED=true
#GATEWAY__RAG__BASE_URL=http://rag:8421
# Loopback host port for the terminal client (host side only).
#GATEWAY_PORT=8420
# Remote access (instead of loopback): set the port mapping to 0.0.0.0 in
# compose.yaml AND require pairing here.
#GATEWAY__AUTH__MODE=paired

# ── RAG — required ────────────────────────────────────────────────────────────
RAG__TOKENIZER__PATH=/models/tokenizer.json
# A directory under /models containing your sentence-transformers model.
RAG__EMBEDDING__MODEL=/models/bge-small-en-v1.5
RAG__EMBEDDING__DEVICE=cpu        # set to cuda if you enable the GPU block in compose.yaml
